  "faq": {
    "mag": [
      {
        "q": "What is a SOTA Mag feature?",
        "a": "A professionally written editorial piece spotlighting your music, art, and story — published on SOTA Mag and shared with our audience."
      },
      {
        "q": "How much does a feature cost?",
        "a": "Features start at $55 for a standard write-up and $75 for a headliner spot. Final pricing depends on the artist and scope, so you’ll receive a custom quote after submitting."
      },
      {
        "q": "What do I need to submit?",
        "a": "6–8 high-quality photos (JPEG or PNG), links to your music or portfolio, any details you’d like highlighted, and payment of the write-up fee before work begins."
      },
      {
        "q": "How many revisions are included?",
        "a": "Up to two rounds of revisions, so your feature reads exactly the way you want."
      },
      {
        "q": "How long does my feature stay live?",
        "a": "Your feature stays published on SOTA Mag for up to one year, giving you long-term visibility."
      },
      {
        "q": "When do I pay?",
        "a": "The write-up fee is due before work begins. You’ll receive payment details along with your quote."
      },
      {
        "q": "Who writes the feature?",
        "a": "Every feature is researched and written by the SOTA Mag editorial team."
      },
      {
        "q": "How long does it take?",
        "a": "Turnaround depends on the current queue and the scope of your feature; you’ll get an estimated timeline once your submission is reviewed."
      }
    ],
    "beats": [
      {
        "q": "How do I license a beat?",
        "a": "Open any beat, choose a license tier (MP3, WAV, Trackout, Unlimited, or Exclusive), and check out on BeatStars or buy directly. You’ll receive the files and your license agreement."
      },
      {
        "q": "What’s the difference between a lease and an exclusive?",
        "a": "A lease lets you use the beat within set limits while it stays available to others. An exclusive transfers full ownership and removes the beat from the store."
      },
      {
        "q": "Can I hear a beat before I buy?",
        "a": "Yes; every beat has an instant in-browser preview. Just press play on any track."
      },
      {
        "q": "Do you make custom beats?",
        "a": "Absolutely. Custom production starts at $80 (non-exclusive) and $250 (exclusive). Reach out through the production services section for a quote."
      },
      {
        "q": "What files do I get?",
        "a": "It depends on the tier: a tagless MP3, WAV, and/or full track stems, along with your license agreement."
      },
      {
        "q": "Do you offer mixing, mastering, or songwriting?",
        "a": "Yes; mixing & mastering, songwriting, vocal arrangement, vocal features, and consulting are all available. See the production services list on the Beats page."
      },
      {
        "q": "How do I pay?",
        "a": "Through BeatStars for instant delivery and contracts, or directly via the buy link / email for custom work."
      },
      {
        "q": "Do I keep the rights to the songs I make?",
        "a": "With a lease you own your recording within the license terms; with an exclusive you own the beat outright. The license PDF spells out exactly what’s included."
      }
    ]
  },
